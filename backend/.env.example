# Flask security keys - change both values before deploying to production
SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_SECRET_KEY=change-me-jwt-secret-use-a-long-random-string

# Firebase - set EITHER path to JSON file OR the full JSON string (for cloud deployment)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=path/to/serviceAccountKey.json
FIREBASE_CREDENTIALS_JSON=

# Google OAuth - get from Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Razorpay - get from Razorpay Dashboard -> Settings -> API Keys
# Use rzp_test_ keys for development, rzp_live_ for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Frontend URL - update to your deployed frontend URL in production
FRONTEND_URL=http://localhost:5173

# WhatsApp Business API / notification automation
# Set WHATSAPP_PROVIDER=meta to send real WhatsApp Cloud API messages.
# Keep dry_run for development; messages will be logged and stored in notification_logs.
WHATSAPP_PROVIDER=dry_run
WHATSAPP_ACCESS_TOKEN=your-meta-whatsapp-cloud-api-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_API_VERSION=v20.0
WHATSAPP_DEFAULT_COUNTRY_CODE=91
ADMIN_WHATSAPP_NUMBERS=919876543210,919812345678
NOTIFICATION_SCHEDULER_ENABLED=true
NOTIFICATION_SCHEDULER_INTERVAL_SECONDS=60
PAYMENT_EXPIRATION_HOURS=24